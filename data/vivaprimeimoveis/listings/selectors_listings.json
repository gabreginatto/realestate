  "extractionPattern": {
    "getAllListings": {
      "description": "Extract all listing data from current page",
      "playwright": "await page.locator('a[href*=\"/imovel/\"]').all().then(cards => Promise.all(cards.map(async card => ({ url: await card.getAttribute('href'), location: await card.getByRole('heading', { level: 2 }).textContent(), price: await card.locator('..').locator('text=/R\\$/').textContent() }))))",
      "why": "Iterates through all cards and extracts key data in parallel",
      "fallbacks": []
    },
    "paginateThroughAll": {
      "description": "Navigate through all pages collecting listings",
      "playwright": "while (await page.locator('a[href*=\"pg=\"]').last().isVisible()) { /* extract data */; await page.locator('a[href*=\"pg=\"]').last().click(); await page.waitForLoadState('networkidle'); }",
      "why": "Loop through pagination until last page is reached",
