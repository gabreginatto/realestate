# Database Configuration
DATABASE_TYPE=postgresql  # postgresql, mongodb, or sqlite
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=realestate
DATABASE_USER=your_username
DATABASE_PASSWORD=your_password

# SQLite (alternative)
# SQLITE_DB_PATH=data/realestate.db

# MongoDB (alternative)
# MONGODB_URI=mongodb://localhost:27017/realestate

# Crawling Configuration
CRAWL_DELAY=2  # Seconds between requests
MAX_CONCURRENT_REQUESTS=5
REQUEST_TIMEOUT=30
USER_AGENT=Mozilla/5.0 (compatible; RealEstateCrawler/1.0)

# Rate Limiting
REQUESTS_PER_MINUTE=30
REQUESTS_PER_HOUR=1000

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_TO_FILE=true
LOG_FILE_PATH=logs/app.log

# API Keys (if needed for certain platforms)
# ZILLOW_API_KEY=your_api_key_here
# REALTOR_API_KEY=your_api_key_here
# REDFIN_API_KEY=your_api_key_here

# Scheduling
ENABLE_SCHEDULER=false
CRAWL_INTERVAL_HOURS=24

# Data Storage
SAVE_RAW_HTML=false
SAVE_IMAGES_LOCALLY=false
MAX_IMAGES_PER_LISTING=10

# Notifications (optional)
ENABLE_NOTIFICATIONS=false
NOTIFICATION_EMAIL=your_email@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_password

# Development
DEBUG_MODE=false
ENABLE_CACHE=true
CACHE_EXPIRY_HOURS=24
